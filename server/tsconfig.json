{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "rootDir": ".", // ← "src" se "." karo
    "outDir": "./dist",
    "exclude": [
      "node_modules",
      "dist",
      "generated"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
}